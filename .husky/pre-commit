#!/usr/bin/env sh
# Lightweight pre-commit hook (no Husky dependency required).
# Install: cp .husky/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# 1) Block staged files with obvious secrets
if git diff --cached --name-only | xargs grep -lE "(sk-ant-[a-zA-Z0-9]{20,}|sk_live_[a-zA-Z0-9]{20,}|AIza[0-9A-Za-z_-]{35}|ghp_[A-Za-z0-9]{36})" 2>/dev/null; then
  echo "❌ Aborting: possible API key in staged files"
  exit 1
fi

# 2) Block .env files (other than .env.example)
if git diff --cached --name-only | grep -E "^\.env(\.|$)" | grep -vE "^\.env\.example$"; then
  echo "❌ Aborting: .env file staged. Add to .gitignore."
  exit 1
fi

# 3) Quick typecheck on TS files
if git diff --cached --name-only | grep -qE "\.(ts|tsx)$"; then
  echo "▶ typecheck..."
  npx tsc --noEmit || { echo "❌ typecheck failed"; exit 1; }
fi

echo "✅ pre-commit checks passed"
