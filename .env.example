# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-32-byte-hex-secret

# Optional: separate key for PII encryption. Falls back to AUTH_SECRET if unset.
# Production strongly recommended to set independently for key-rotation safety.
ENCRYPTION_KEY=replace-with-different-32-byte-hex-secret

# Set to true behind a reverse proxy (Fly, Vercel, etc.)
AUTH_TRUST_HOST=true

# Override the SQLite file path. Useful for testing or custom deployments.
# HR_DB_PATH=/data/hr-os.db

# Required when deploying to Turso (libSQL)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=...

# Anthropic API key — when set, AI履歴書解析 uses real Claude API.
# Without it, parsing falls back to clearly-labeled mock data.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_RESUME_MODEL=claude-opus-4-7   # optional override; default is claude-opus-4-7

# Bearer token for /api/cron/reminders. Generate with: openssl rand -hex 32
# CRON_SECRET=replace-with-32-byte-hex

# SSO providers (NextAuth). Either or both may be configured. When set,
# matching login buttons appear. SSO requires the email to match a
# pre-provisioned user in our DB — admin must invite via /settings/users first.
#
# Google: callback URL = ${APP_BASE_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=...
#
# Azure AD / Microsoft Entra ID: callback URL = ${APP_BASE_URL}/api/auth/callback/microsoft-entra-id
# AZURE_AD_CLIENT_ID=...
# AZURE_AD_CLIENT_SECRET=...
# AZURE_AD_TENANT_ID=...   # optional, defaults to "common"

# Email (Resend). Without these, emails are logged to console only.
# RESEND_API_KEY=re_...
# EMAIL_FROM=HR OS <noreply@your-domain.com>
# EMAIL_REPLY_TO=hr@your-domain.com
# EMAIL_DEBUG=1   # log full HTML body to console when in console-fallback mode
# APP_BASE_URL=https://your-domain.com   # used for links in email templates

# Sentry error monitoring. Without these the app runs unchanged and errors
# only go to console. Server DSN goes to SENTRY_DSN; client DSN is exposed
# to the browser via NEXT_PUBLIC_SENTRY_DSN (can be the same value).
# SENTRY_DSN=https://...@oXXXX.ingest.sentry.io/YYYY
# NEXT_PUBLIC_SENTRY_DSN=https://...@oXXXX.ingest.sentry.io/YYYY
# SENTRY_ENV=production
# SENTRY_ORG=your-org
# SENTRY_PROJECT=hr-os
# SENTRY_RELEASE=git-sha-or-version  # set in CI from $GITHUB_SHA for release tracking
# SENTRY_AUTH_TOKEN=...              # for source-map upload during build

# Resend webhook (set after configuring webhook in Resend dashboard)
# RESEND_WEBHOOK_SECRET=...

# IP allowlist per role (comma-separated CIDR or single IP). When set, only
# requests from listed IPs are accepted for that role at login.
# IP_ALLOWLIST_GROUP_ADMIN=10.0.0.0/8,203.0.113.5
# IP_ALLOWLIST_ENTITY_HR=10.0.0.0/8

# AI API monthly budget (USD). Triggers email at 80% / 100%.
# AI_MONTHLY_BUDGET_USD=100
# BUDGET_ALERT_EMAIL=ops@your-domain.jp

# Skip the seed (mock data). Production should always set this to "1"
# (or rely on NODE_ENV=production which already skips seeding).
# HR_SKIP_SEED=1
